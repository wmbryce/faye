# Faye env. On the Hetzner box this lives at /opt/faye/.env and is mounted
# into the `web` container by docker-compose.yml.
# In CI, vars are provided via the workflow `env:` block, not this file.

# Postgres (local dev)
DATABASE_URL=postgres://postgres@localhost:5432/faye_dev
DATABASE_URL_TEST=postgres://postgres@localhost:5432/faye_test

# Postgres password (compose-only — docker-compose builds DATABASE_URL from this)
POSTGRES_PASSWORD=replace-with-strong-random-password

# Auth
AUTH_TOKEN_SECRET=replace-with-32-char-random
OPERATOR_EMAIL=michael@wmbryce.dev

# Resend
RESEND_API_KEY=re_xxx
RESEND_FROM=Faye <onboarding@resend.dev>

# App
APP_URL=http://localhost:3000
NODE_ENV=development

# FB webhook (used by app/api/fb/webhook). Pick any opaque string for VERIFY_TOKEN;
# APP_SECRET is the Meta app secret used to sign payloads.
FB_WEBHOOK_VERIFY_TOKEN=replace-with-random-string
FB_WEBHOOK_APP_SECRET=replace-with-meta-app-secret

# Pinned image tag (compose reads this when pulling from GHCR). Latest is OK.
FAYE_IMAGE_TAG=latest

# Backups (used by deploy/backup.sh)
BACKUP_BUCKET=faye-backups
BACKUP_PREFIX=db
RETAIN_DAYS=30
