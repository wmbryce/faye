# Faye system crontab (Hetzner CX22). All times UTC.
# Lines below include the `faye` user column for /etc/cron.d/faye.
# For `crontab -u faye -e`, drop the `faye` column.

# Publisher tick — every 5 minutes. Publishes any pending ads whose publishAt has elapsed.
*/5 * * * * faye cd /opt/faye && /usr/bin/pnpm exec tsx scripts/publish-tick.ts >> /var/log/faye/publish.log 2>&1

# Metrics pull — daily for all active campaigns. Defaults to yesterday's date.
0 8 * * * faye cd /opt/faye && /usr/bin/pnpm exec tsx scripts/metrics-pull.ts --all >> /var/log/faye/metrics.log 2>&1

# Bandit step — daily, 30 min after metrics pull. Same default date semantics.
30 8 * * * faye cd /opt/faye && /usr/bin/pnpm exec tsx scripts/bandit-step.ts --all >> /var/log/faye/bandit.log 2>&1

# Daily LLM loop — runs HOURLY. Per-campaign filter inside picks only campaigns
# whose artist-local hour is 09:00. Collapses 24 tz buckets into one crontab line.
0 * * * * faye cd /opt/faye && (/usr/bin/pnpm exec tsx scripts/daily.ts --all && /usr/bin/pnpm exec tsx scripts/digest.ts --all) >> /var/log/faye/daily.log 2>&1
